# =============================================================================
# /etc/nginx/conf.d/stub_status.conf
# Géré par Ansible (rôle nginx_web)
# =============================================================================
# Expose les métriques Nginx via ngx_http_stub_status_module
# Port dédié 8081 — évite le conflit avec le vhost par défaut port 80
# Accessible uniquement en local pour Zabbix Agent 2
# =============================================================================

server {
    listen 127.0.0.1:8081;
    server_name localhost;

    location /nginx_status {
        stub_status;
        allow 127.0.0.1;
        deny all;
    }
}