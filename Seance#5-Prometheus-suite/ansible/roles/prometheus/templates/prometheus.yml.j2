# /etc/prometheus/prometheus.yml — Généré par Ansible

global:
  scrape_interval:     15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alert.rules.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["localhost:9093"]

scrape_configs:

  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]

  # Node Exporter sur VM 1 (bare-metal, protégé par UFW)
  - job_name: "node-cible"
    static_configs:
      - targets: ["{{ cible_ip }}:9100"]

  # API FastAPI sur VM 1
  - job_name: "fastapi-cible"
    static_configs:
      - targets: ["{{ cible_ip }}:5000"]
