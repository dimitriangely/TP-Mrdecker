Vagrant.configure("2") do |config|

  # Box de base commune : Ubuntu 22.04 LTS
  config.vm.box = "ubuntu/jammy64"

  # Désactive la mise à jour automatique de la box (optionnel, pour accélérer)
  config.vm.box_check_update = false

  # ─────────────────────────────────────────────
  # VM 1 : monitoring  (Prometheus + Grafana + Node Exporter)
  # ─────────────────────────────────────────────
  config.vm.define "monitoring" do |mon|
    mon.vm.hostname = "monitoring"

    # Réseau privé : IP fixe pour que les VMs se parlent
    mon.vm.network "private_network", ip: "192.168.56.10"

    # Redirection de ports vers l'hôte (accès depuis le navigateur Windows)
    mon.vm.network "forwarded_port", guest: 9090, host: 9090   # Prometheus UI
    mon.vm.network "forwarded_port", guest: 3000, host: 3000   # Grafana UI
    mon.vm.network "forwarded_port", guest: 9100, host: 9101   # Node Exporter (monitoring)
    mon.vm.network "forwarded_port", guest: 5000, host: 5000   # Flask API
    mon.vm.network "forwarded_port", guest: 9093, host: 9093   # Alertmanager UI

    mon.vm.provider "virtualbox" do |vb|
      vb.name   = "tp-monitoring"
      vb.cpus   = 2
      vb.memory = 2048
      vb.linked_clone = true
    end

    # Provisioning Ansible (depuis l'hôte)
    # ansible_local si tu n'as pas Ansible sur Windows
    mon.vm.provision "ansible_local" do |ansible|
      ansible.playbook       = "ansible/playbook-monitoring.yml"
      ansible.install        = true          # Installe Ansible dans la VM si absent
      ansible.compatibility_mode = "2.0"
    end
  end

  # ─────────────────────────────────────────────
  # VM 2 : target  (Node Exporter uniquement)
  # ─────────────────────────────────────────────
  config.vm.define "target" do |tgt|
    tgt.vm.hostname = "target"

    tgt.vm.network "private_network", ip: "192.168.56.20"
    tgt.vm.network "forwarded_port", guest: 9100, host: 9102   # Node Exporter (target)

    tgt.vm.provider "virtualbox" do |vb|
      vb.name   = "tp-target"
      vb.cpus   = 1
      vb.memory = 1024
      vb.linked_clone = true
    end

    tgt.vm.provision "ansible_local" do |ansible|
      ansible.playbook       = "ansible/playbook-target.yml"
      ansible.install        = true
      ansible.compatibility_mode = "2.0"
    end
  end

end