global:
  resolve_timeout: 5m

route:
  receiver: slack-m2shop
  group_by: ["alertname", "host"]
  group_wait: 5s
  group_interval: 30s
  repeat_interval: 1h

receivers:
  - name: slack-m2shop
    slack_configs:
      - api_url: "{{ slack_webhook_url }}"
        channel: "#alertes-m2shop"
        send_resolved: true
        title: "{{ '{{' }} .CommonLabels.alertname {{ '}}' }} - {{ '{{' }} .Status {{ '}}' }}"
        text: >-
          *Heure :* {{ '{{' }} (index .Alerts 0).StartsAt.Format "2006-01-02 15:04:05 MST" {{ '}}' }}
          *Hôte :* {{ '{{' }} .CommonLabels.host {{ '}}' }} (zone {{ '{{' }} .CommonLabels.zone {{ '}}' }})
          *Impact :* {{ '{{' }} (index .Alerts 0).Annotations.description {{ '}}' }}
    webhook_configs:
      - url: "http://10.0.20.20:9095/alert"
        send_resolved: false
