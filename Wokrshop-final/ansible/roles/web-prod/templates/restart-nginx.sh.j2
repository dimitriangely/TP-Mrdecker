#!/bin/bash
# restart-nginx.sh
# Géré par Ansible - TP Observabilité Sécurisée - Jalon D
#
# Script de remédiation automatique exécuté par le compte non-root "healer"
# via une règle sudoers chirurgicale (une seule commande exacte autorisée,
# cf. /etc/sudoers.d/supervision). Ne fait rien d'autre que relancer Nginx
# et journaliser l'action - délibérément minimal pour limiter la surface
# d'attaque de ce qui s'exécute avec un privilège élevé.

set -euo pipefail

LOG_FILE="/var/log/healer/remediation.log"
TIMESTAMP=$(date -u "+%Y-%m-%dT%H:%M:%SZ")

echo "[${TIMESTAMP}] Déclenchement de la remédiation automatique : relance de nginx.service" >> "${LOG_FILE}"

if sudo -n /usr/bin/systemctl restart nginx.service; then
    echo "[${TIMESTAMP}] Remédiation réussie : nginx.service relancé" >> "${LOG_FILE}"
    exit 0
else
    echo "[${TIMESTAMP}] ÉCHEC de la remédiation : nginx.service n'a pas pu être relancé" >> "${LOG_FILE}"
    exit 1
fi
