# web-config.yml - Node Exporter
# Géré par Ansible - TP Observabilité Sécurisée - Jalon B
#
# Le mot de passe en clair n'apparaît JAMAIS ici : seul le hash bcrypt est
# stocké, généré à la volée par Ansible via le filtre password_hash, à partir
# de la valeur déchiffrée du vault (vault_node_exporter_basic_auth_password).

tls_server_config:
  cert_file: /etc/node_exporter/tls/node_exporter.crt
  key_file: /etc/node_exporter/tls/node_exporter.key
  min_version: TLS13
  max_version: TLS13

basic_auth_users:
  {{ node_exporter_basic_auth_user }}: "{{ node_exporter_basic_auth_password | password_hash('bcrypt') }}"
